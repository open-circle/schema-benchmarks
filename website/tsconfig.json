{
  "extends": "../tsconfig.base.json",
  "include": [
    ".storybook/**/*",
    "./vite.config.ts",
    "./postcss.config.ts",
    "./preview.ts",
    "./src/**/*",
    "./test/**/*",
    "./vite/**/*",
    "./offline/**/*",
    "./e2e/**/*"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "allowArbitraryExtensions": true,

    "paths": {
      "#src/*": ["./src/*"],
      "#test/*": ["./test/*"],
      "#storybook/*": ["./.storybook/*"],
      "#e2e/*": ["./e2e/*"],
      "content-collections": ["./.content-collections/generated"]
    },

    "types": ["node", "vite/client", "vite-plugin-svgr/client", "vite-plugin-pwa/client"]
  }
}
