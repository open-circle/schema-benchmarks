{
  "extends": "../tsconfig.base.json",
  "include": ["libraries/**/*", "src/**/*"],
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "paths": {
      "#src": ["./src/index.ts"]
    },
    // remove tsdown dependency once https://github.com/voidzero-dev/vite-plus/issues/1500 is resolved
    "types": ["node", "tsdown/client"],
    "declaration": true,
    "declarationMap": true
  }
}
